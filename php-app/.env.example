# Application
APP_NAME="Connect IT"
APP_ENV=development
APP_URL=http://localhost/php-app
APP_DEBUG=true
APP_KEY=change_this_to_a_random_32_char_string

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=connectit_db
DB_USER=root
DB_PASS=

# Session
SESSION_LIFETIME=86400
SESSION_NAME=connectit_session

# Security
CSRF_TOKEN_LIFETIME=3600

# Logging
LOG_CHANNEL=file
LOG_LEVEL=debug

# File Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=public/uploads

# AI Chatbot (optional)
AI_API_KEY=
AI_MODEL=gpt-3.5-turbo
AI_ENDPOINT=https://api.openai.com/v1/chat/completions

# Email (optional)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@connectit.com
MAIL_FROM_NAME="Connect IT"
